{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "Siphon",
    "version": "1.0.0",
    "identifier": "com.siphon.desktop",
    "build": {
        "frontendDist": "../renderer"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Siphon",
                "label": "main",
                "width": 1180,
                "height": 780,
                "minWidth": 860,
                "minHeight": 580,
                "decorations": false,
                "transparent": false,
                "center": true,
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost http://asset.localhost data: blob: https: http:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src ipc: http://ipc.localhost https://ipc.localhost https: http:",
            "assetProtocol": {
                "enable": true,
                "scope": ["**"]
            }
        }
    },
    "plugins": {
        "deep-link": {
            "desktop": {
                "schemes": ["siphon"]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installMode": "currentUser"
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.15"
        }
    }
}
